# =============================================================================
# Mongol Beauty — root .env (used by Docker Compose)
# =============================================================================
# Copy to `.env` at repo root:
#   cp .env.example .env
#
# Compose reads these variables when you run `docker compose up` (Docker
# automatically loads a file named `.env` next to docker-compose.yml).

# PostgreSQL (must match apps/api/.env)
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=mongol_beauty
DB_PORT=5432
