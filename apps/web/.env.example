# =============================================================================
# Mongol Beauty — Web (Vite + React + Apollo)
# =============================================================================
# Copy:  cp apps/web/.env.example apps/web/.env
#
# Dev: leave VITE_GRAPHQL_URL unset to use the Vite proxy (/graphql → backend).
# Prod build: set the full GraphQL URL of your API.

# Optional — omit in dev to use Vite proxy (see vite.config.ts server.proxy)
# VITE_GRAPHQL_URL=http://localhost:4000/graphql
