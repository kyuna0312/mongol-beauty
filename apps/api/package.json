{
  "name": "@mongol-beauty/api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"src/**/*.ts\" --max-warnings 0",
    "lint:fix": "eslint \"src/**/*.ts\" --fix",
    "type-check": "tsc --noEmit",
    "test": "NODE_ENV=test jest --config jest.config.cjs",
    "seed": "ts-node -r tsconfig-paths/register src/scripts/seed.ts",
    "seed:prod": "node dist/scripts/seed.js",
    "create-admin": "ts-node -r tsconfig-paths/register src/scripts/create-admin.ts",
    "create-demo-user": "ts-node -r tsconfig-paths/register src/scripts/create-demo-user.ts",
    "migration:generate": "npx typeorm-ts-node-commonjs -d src/data-source.ts migration:generate",
    "migration:run": "npm run build && npx typeorm migration:run -d dist/data-source.js",
    "migration:revert": "npx typeorm migration:revert -d dist/data-source.js"
  },
  "dependencies": {
    "@apollo/server": "^4.9.5",
    "@nestjs/apollo": "^12.0.11",
    "@nestjs/common": "^10.3.0",
    "@nestjs/config": "^3.1.1",
    "@nestjs/core": "^11.1.18",
    "@nestjs/graphql": "^12.0.9",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/platform-express": "^10.3.0",
    "@nestjs/terminus": "^10.1.1",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/typeorm": "^10.0.1",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "compression": "^1.8.1",
    "dataloader": "^2.2.0",
    "graphql": "^16.8.1",
    "graphql-depth-limit": "^1.1.0",
    "graphql-query-complexity": "^1.1.0",
    "graphql-upload": "^13.0.0",
    "nodemailer": "^7.0.12",
    "pg": "^8.11.3",
    "prom-client": "^15.1.3",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.17"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.2.1",
    "@nestjs/schematics": "^10.0.3",
    "@types/bcrypt": "^6.0.0",
    "@types/compression": "^1.8.1",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.10.5",
    "@types/nodemailer": "^7.0.5",
    "dotenv": "^17.2.3",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.3.3"
  }
}
