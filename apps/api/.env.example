# =============================================================================
# Mongol Beauty — API (NestJS + GraphQL + TypeORM)
# Usage: cp apps/api/.env.example apps/api/.env
# =============================================================================

# ── Database ──────────────────────────────────────────────────────────────────
# Host is localhost when DB runs via Docker with a published port
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=mongol_beauty

# ── Server ────────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ── CORS ──────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ── Secrets (required in production, dev values are fine locally) ─────────────
JWT_SECRET=dev-jwt-secret-change-in-prod
INTERNAL_SERVICE_SECRET=dev-internal-secret-change-in-prod
INTERNAL_SERVICE_TOKEN=dev-internal-token-change-in-prod

# ── Demo users (used by yarn create-admin / yarn create-demo-user) ────────────
# ADMIN_EMAIL=admin@mcosmetics.mn
# ADMIN_PASSWORD=admin123
# ADMIN_NAME=Админ
# DEMO_USER_EMAIL=demo@mcosmetics.mn
# DEMO_USER_PASSWORD=demo1234
# DEMO_USER_NAME=Демо хэрэглэгч

# ── Rate limiting ─────────────────────────────────────────────────────────────
# THROTTLE_TTL=60000
# THROTTLE_LIMIT=100

# ── Schema sync ───────────────────────────────────────────────────────────────
# Leave unset in dev (auto-sync on). Set false when using migrations only.
# DB_SYNCHRONIZE=false
