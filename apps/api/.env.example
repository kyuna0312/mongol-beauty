# =============================================================================
# Mongol Beauty — API (NestJS + GraphQL + TypeORM)
# =============================================================================
# Copy:  cp apps/api/.env.example apps/api/.env
#
# Run from repo root: `yarn dev:api` or `npm run dev:api -w @mongol-beauty/api`
# (or `cd apps/api && npm run start:dev`).

# --- Database (PostgreSQL) ---
# Host is localhost when the DB runs via Docker and port is published to the host.
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=mongol_beauty

# Server
PORT=4000
NODE_ENV=development

# CORS — must match the Vite dev server origin
FRONTEND_URL=http://localhost:5173

# JWT (required in production; use a long random string)
JWT_SECRET=change-me-in-development-only

# --- Demo users (optional; used by `yarn create-admin` / `yarn create-demo-user`) ---
# ADMIN_EMAIL=admin@incellderm.mn
# ADMIN_PASSWORD=admin123
# ADMIN_NAME=Админ
# DEMO_USER_EMAIL=demo@mongol-beauty.local
# DEMO_USER_PASSWORD=demo1234
# DEMO_USER_NAME=Демо хэрэглэгч

# Rate limiting (optional)
# THROTTLE_TTL=60000
# THROTTLE_LIMIT=100

# --- Schema sync (local development) ---
# When unset: synchronize is ON in non-production (tables created/updated from entities).
# Set to false when you rely on TypeORM migrations only (recommended for staging/prod).
# DB_SYNCHRONIZE=true
# DB_SYNCHRONIZE=false
