# =============================================================================
# Mongol Beauty — Production environment
# Usage: cp .env.prod.example .env.prod  then fill in every <value>
# =============================================================================

# ── Domains ──────────────────────────────────────────────────────────────────
# Single domain — API is proxied via /graphql path on the same domain
DOMAIN=mcosmetics.mn
FRONTEND_URL=https://mcosmetics.mn
LETSENCRYPT_EMAIL=<your@email.com>

# ── Database ──────────────────────────────────────────────────────────────────
# Use strong random values — never reuse dev defaults in production
DB_USER=mongol_beauty_prod
DB_PASSWORD=<strong-random-password>
DB_NAME=mongol_beauty
DB_PORT=5432
DB_SYNCHRONIZE=false

# ── App secrets ───────────────────────────────────────────────────────────────
# Generate both with: openssl rand -hex 32
JWT_SECRET=<64-char-hex-string>
INTERNAL_SERVICE_SECRET=<64-char-hex-string>

# ── Cloudflare R2 receipt storage ─────────────────────────────────────────────
# Set RECEIPT_STORAGE_DRIVER=local to use local disk (dev only)
RECEIPT_STORAGE_DRIVER=r2
# R2 Account ID — from Cloudflare Dashboard → R2 → Account ID (top right)
CF_R2_ACCOUNT_ID=<cloudflare-account-id>
# R2 API token credentials — create at: Dashboard → R2 → Manage R2 API Tokens
CF_R2_ACCESS_KEY_ID=<r2-access-key-id>
CF_R2_SECRET_ACCESS_KEY=<r2-secret-access-key>
# Name of your R2 bucket (create it at: Dashboard → R2 → Create bucket)
CF_R2_BUCKET=mongol-beauty-receipts
# Public URL for serving files — either custom domain or r2.dev URL:
#   Custom domain:  https://uploads.mcosmetics.mn
#   Default r2.dev: https://pub-<token>.r2.dev  (enable in bucket Settings → Public access)
CF_R2_PUBLIC_URL=https://uploads.mcosmetics.mn
# Max receipt upload size in bytes (default 5 MB)
RECEIPT_MAX_BYTES=5242880

# ── Backups ───────────────────────────────────────────────────────────────────
# Must be a writable path on the host (create it first: mkdir -p <path>)
BACKUP_DIR=/home/<user>/backups/mongol-beauty
